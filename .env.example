# Sentinel — docker-compose environment.
# Copy to .env and adjust. Used by docker-compose.yml.

# Database
DB_PASSWORD=changeme
DB_PORT=5432

# Server
# FRONTEND_PORT: host port for the web UI. BACKEND_PORT: host port for the API.
FRONTEND_PORT=3000
BACKEND_PORT=3001
ENVIRONMENT=production
LOG_LEVEL=info
TIMEZONE=UTC

# Database admin tool (Adminer, optional web UI for the database).
# ADMINER_PORT is the host port. To START Adminer, keep COMPOSE_PROFILES=adminer;
# to SKIP it, set COMPOSE_PROFILES= (empty). ADMINER_ENABLED is informational.
ADMINER_ENABLED=true
ADMINER_PORT=8080
COMPOSE_PROFILES=adminer

# Authentication — set a strong random secret of at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Slack (optional)
SLACK_WEBHOOK_URL=

# Discord (optional)
DISCORD_WEBHOOK_URL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ntfy (optional)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=

# Custom Webhook (optional)
WEBHOOK_URL=

# Docker Registry (for pulling published images)
DOCKER_REGISTRY=ghcr.io
IMAGE_TAG=latest
