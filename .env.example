# Sentinel — docker-compose environment.
# Copy to .env and adjust. Used by docker-compose.yml.

# Database
DB_PASSWORD=changeme
DB_PORT=5432

# Server
PORT=3000
ENVIRONMENT=production
LOG_LEVEL=info
TIMEZONE=UTC

# Authentication — set a strong random secret of at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Slack (optional)
SLACK_WEBHOOK_URL=

# Discord (optional)
DISCORD_WEBHOOK_URL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ntfy (optional)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=

# Custom Webhook (optional)
WEBHOOK_URL=

# Docker Registry (for pulling published images)
DOCKER_REGISTRY=ghcr.io
IMAGE_TAG=latest
