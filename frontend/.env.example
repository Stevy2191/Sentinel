# Sentinel frontend configuration.
# Copy to .env.local and adjust as needed.
#
# NOTE: This is a Vite app. Env vars are exposed via import.meta.env, and only
# keys with the VITE_ or REACT_APP_ prefix are exposed (see vite.config.ts).

# API base URL. Leave unset to use the dev-server proxy (recommended): requests
# go to "/api/v1" on the Vite dev server, which proxies to the backend so the
# browser makes same-origin calls (no CORS needed). Set an absolute URL only if
# the backend enables CORS.
# REACT_APP_API_URL=http://localhost:3001/api/v1

# WebSocket URL (reserved for future live updates).
REACT_APP_WS_URL=ws://localhost:3001
